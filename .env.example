DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
PORT=8787

# 岗位源：auto 默认优先使用腾讯校招 skill，失败回退本地岗位库；local 强制本地；tencent 强制腾讯
JOB_SOURCE_PROVIDER=auto
TENCENT_SKILL_DIR=/Users/mike/.workbuddy/skills/skill_2054903442024890368
TENCENT_SKILL_PYTHON=python3
# 腾讯岗位每日缓存；分析时从缓存中本地推荐，只为候选岗位补充 JD 详情
TENCENT_JD_CACHE_DB=data/tencent-jobs.sqlite
TENCENT_RECOMMEND_TOP_N=5
TENCENT_CACHE_DETAIL_CANDIDATES=12

# 可选：指定后端岗位库文件。默认读取 server/data/jobs.json，其次 server/data/jobs.csv
JOBS_FILE=data/jobs.json
